# Copy into Vercel Project Settings → Environment Variables.
# NEXT_PUBLIC_* are inlined at build time — redeploy after changes.
# See docs/DEPLOY_RAILWAY_VERCEL.md

NEXT_PUBLIC_TS_API_URL=https://YOUR-RAILWAY-API-HOST
NEXT_PUBLIC_SITE_URL=https://YOUR-VERCEL-WEB-HOST
# Optional; dashboard falls back to wss:// from NEXT_PUBLIC_TS_API_URL
NEXT_PUBLIC_WS_URL=wss://YOUR-RAILWAY-API-HOST
NEXT_PUBLIC_SENTRY_DSN=
