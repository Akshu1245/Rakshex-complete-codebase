# DevPulse Environment Configuration
# Copy to .env and fill in values before running locally or deploying.
# See server/_core/env.ts for validation rules.

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ── Auth (REQUIRED in production) ─────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dev-secret-do-not-use-in-production-change-me-32chars-min

# Optional vault key for encrypting enterprise credentials (32+ chars)
# Falls back to JWT_SECRET if unset
RAKSHEX_VAULT_KEY=

# ── Database (REQUIRED in production) ─────────────────────────────────
DATABASE_URL=postgresql://root:devpulse@127.0.0.1:5432/devpulse
# Required for docker-compose.prod.yml (generate a strong password):
POSTGRES_PASSWORD=

# ── Redis (optional — in-memory fallback in dev) ──────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Manus OAuth (optional) ──────────────────────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=https://auth.manus.app
OWNER_OPEN_ID=

# ── LLM Providers (at least one recommended) ──────────────────────────
MINIMAX_API_KEY=
MINIMAX_API_URL=https://api.minimax.io/v1
MINIMAX_MODEL=minimaxai/minimax-m2.7
BUILT_IN_FORGE_API_URL=https://api.manus.app/forge
BUILT_IN_FORGE_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324:free

# ── Email (SMTP) ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@devpulse.io

# ── Payments (Razorpay — India) ───────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Payments (Stripe — USD, optional) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Monitoring ────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=info

# ── Notifications ─────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── GitHub App Integration ────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# ── Internal / Gateway ────────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=
GATEWAY_SERVICE_TOKEN=

# ── Azure Enterprise (optional) ───────────────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_KEY_VAULT_URL=

# ── GitHub Copilot Enterprise (optional) ──────────────────────────────
GITHUB_ENTERPRISE_SLUG=
GITHUB_COPILOT_TOKEN=

# ── OpenTelemetry (optional) ──────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATE=0.1

# ── Research APIs (optional) ────────────────────────────────────────────
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# ── Frontend (devpulse-frontend/.env.local) ───────────────────────────
# NEXT_PUBLIC_TS_API_URL=http://localhost:3000
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_CRISP_WEBSITE_ID=
# NEXT_PUBLIC_ENABLE_ANALYTICS=false
# Optional public beta date for the website countdown (ISO 8601). Leave blank to hide it.
NEXT_PUBLIC_LAUNCH_DATE=
