# ── RakshEx / DevPulse environment template ─────────────────────────────────
# Copy to .env and fill in real values. Never commit secrets.
# Schema source of truth: apps/api/_core/env.ts

NODE_ENV=development
PORT=3000

# Auth — min 32 chars in production
JWT_SECRET=replace-with-32-plus-char-random-secret
OWNER_OPEN_ID=

# Database (PostgreSQL) — required in production
DATABASE_URL=postgresql://rakshex:password@localhost:5432/rakshex

# Redis — REQUIRED in production (no in-memory MockRedis / mock BullMQ)
REDIS_URL=redis://localhost:6379

# OAuth
VITE_APP_ID=
OAUTH_SERVER_URL=https://auth.manus.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# LLM / Forge (optional)
BUILT_IN_FORGE_API_URL=https://api.manus.app/forge
BUILT_IN_FORGE_API_KEY=
MINIMAX_API_KEY=
MINIMAX_API_URL=https://api.minimax.io/v1
MINIMAX_MODEL=minimaxai/minimax-m2.7
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-chat-v3-0324:free

# SMTP — REQUIRED in production for transactional mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@rakshex.in
APP_URL=http://localhost:3000

# Notifications / monitoring
SLACK_WEBHOOK_URL=
SENTRY_DSN=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend + CORS (no wildcards — list explicit origins)
# Production dual-domain example:
#   FRONTEND_URL=https://www.rakshex.in
#   CORS_ORIGINS=https://rakshex.in,https://www.rakshex.in,https://yc7y9pq9.insforge.site
FRONTEND_URL=http://localhost:3000
# Comma-separated extra origins, e.g. https://app.example.com,https://staging.example.com
CORS_ORIGINS=

# Protect GET /metrics — required in production (Bearer token)
METRICS_TOKEN=replace-with-random-metrics-scrape-token

# GitHub App + webhooks — GITHUB_WEBHOOK_SECRET required in production
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

INTERNAL_SERVICE_SECRET=
GATEWAY_SERVICE_TOKEN=
LOG_LEVEL=info

# Research / enterprise (optional)
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_KEY_VAULT_URL=
GITHUB_ENTERPRISE_SLUG=
GITHUB_COPILOT_TOKEN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SAMPLE_RATE=

# Frontend (apps/web)
# Production: NEXT_PUBLIC_TS_API_URL=https://rakshex-api-production.up.railway.app
NEXT_PUBLIC_TS_API_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Set true only for local sandbox demos — never in production
NEXT_PUBLIC_SANDBOX_MODE=false
