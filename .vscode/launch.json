{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Rakshex VS Code Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension"],
      "outFiles": ["${workspaceFolder}/apps/vscode-extension/dist/**/*.js"],
      "preLaunchTask": "npm: esbuild-watch - vscode-extension"
    }
  ]
}
