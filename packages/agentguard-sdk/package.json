{
  "name": "@rakshex/agentguard-sdk",
  "version": "0.1.0",
  "description": "Rakshex AgentGuard runtime SDK — provider wrappers, privacy modes, telemetry",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo \"@rakshex/agentguard-sdk: ok\"",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agentguard",
    "llm",
    "telemetry",
    "openai",
    "anthropic",
    "governance"
  ],
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
