{
  "name": "@devpulse/sdk",
  "version": "0.1.0",
  "description": "DevPulse AI Runtime Telemetry SDK — drop-in wrapper for LLM providers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./openai": "./dist/wrappers/openai.js",
    "./anthropic": "./dist/wrappers/anthropic.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true }
  },
  "keywords": ["devpulse", "ai", "llm", "telemetry", "observability", "openai", "anthropic"],
  "license": "MIT"
}
