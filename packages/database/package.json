{
  "name": "@rakshex/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./drizzle/schema.ts",
    "./schema-foundation": "./drizzle/schema-foundation.ts",
    "./schema-enterprise": "./drizzle/schema-enterprise.ts",
    "./relations": "./drizzle/relations.ts",
    "./migrate": "./src/migrate.ts",
    "./seed": "./src/seed.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo \"@rakshex/database: lint deferred to root\"",
    "test": "vitest run --config vitest.config.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx src/migrate.ts",
    "db:reset": "tsx src/reset.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
