{
  "name": "devpulse",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && node scripts/add-js-extensions.js",
    "start": "node dist/server/_core/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test --grep=Smoke",
    "test:e2e:integration": "playwright test --grep-invert=Smoke",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test:server && npm run test:frontend && npm run test:vscode",
    "test:server": "vitest run --config vitest.config.ts",
    "test:frontend": "cd devpulse-frontend && npx vitest run",
    "test:vscode": "cd devpulse-vscode && npx vitest run",
    "check": "npx tsc --noEmit",
    "check:all": "npm run check && cd devpulse-vscode && npx tsc --noEmit && cd ../devpulse-frontend && npx tsc --noEmit",
    "install:all": "npm install && cd devpulse-frontend && npm install && cd ../devpulse-vscode && npm install",
    "db:up": "docker compose up -d mysql redis",
    "db:down": "docker compose down",
    "db:migrate": "sh scripts/migrate.sh",
    "prepare": "husky",
    "lint": "npx eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:frontend": "cd devpulse-frontend && npx eslint . --ext .ts,.tsx --max-warnings=0",
    "format": "npx prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "npx prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.2",
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@sentry/node": "^7.100.0",
    "@sentry/opentelemetry": "^10.53.1",
    "@trpc/server": "^11.6.0",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.7.0",
    "bullmq": "^5.0.0",
    "compression": "^1.7.4",
    "cookie": "^1.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jose": "^5.2.0",
    "mysql2": "^3.9.0",
    "nanoid": "^5.0.4",
    "nodemailer": "^8.0.10",
    "pdfkit": "^0.15.0",
    "pg": "^8.21.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.60.0",
    "prom-client": "^15.1.0",
    "rate-limit-redis": "^4.2.0",
    "razorpay": "^2.9.6",
    "redis": "^4.6.0",
    "socket.io": "^4.7.0",
    "sqlstring": "^2.3.3",
    "stripe": "^16.0.0",
    "superjson": "^1.13.3",
    "ws": "^8.21.0",
    "xml-crypto": "^6.0.0",
    "xml2js": "^0.6.2",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npx prettier --write"
    ],
    "*.{json,md}": [
      "npx prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.15.2",
      "ws": ">=8.21.0",
      "postcss": ">=8.5.10",
      "esbuild": ">=0.25.0",
      "@grpc/grpc-js": ">=1.14.4",
      "protobufjs": ">=7.6.3",
      "form-data": ">=4.0.6",
      "@opentelemetry/core": ">=2.8.0",
      "undici": ">=7.28.0",
      "nodemailer": ">=9.0.1"
    }
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.28.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/compression": "^1.7.5",
    "@types/cookie": "^1.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.6.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.5.10",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "google-auth-library": "^10.6.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  }
}
